[
    {
        "name": "site_config",
        "type": "base",
        "system": false,
        "fields": [
            { "name": "company_name", "type": "text", "required": true, "presentable": true },
            { "name": "nib", "type": "text" },
            { "name": "address", "type": "text" },
            { "name": "phone_wa", "type": "text" },
            { "name": "email_official", "type": "email" },
            { "name": "welcome_text", "type": "editor" },
            { "name": "total_members", "type": "text" },
            { "name": "total_assets", "type": "text" }
        ],
        "listRule": "",
        "viewRule": "",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "name": "news",
        "type": "base",
        "system": false,
        "fields": [
            { "name": "title", "type": "text", "required": true, "presentable": true },
            { "name": "slug", "type": "text", "required": true, "unique": true },
            { "name": "content", "type": "editor" },
            { "name": "thumbnail", "type": "file", "options": { "maxSelect": 1 } },
            { "name": "published", "type": "bool" },
            { "name": "category", "type": "select", "options": { "maxSelect": 1, "values": ["Berita", "Pengumuman", "Kegiatan"] } }
        ],
        "listRule": "",
        "viewRule": "",
