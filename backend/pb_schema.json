        "updateRule": "@request.auth.id != ''"
    },
    {
        "name": "hero_banners",
        "type": "base",
        "system": false,
        "fields": [
            { "name": "title", "type": "text", "required": true },
            { "name": "subtitle", "type": "text" },
            { "name": "image_desktop", "type": "file", "required": true, "options": { "maxSelect": 1 } },
            { "name": "active", "type": "bool" }
        ],
        "listRule": "",
        "viewRule": "",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "name": "perangkat_desa",
        "type": "base",
