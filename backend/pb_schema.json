        "type": "base",
        "system": false,
        "fields": [
            { "name": "bku_id", "type": "relation", "required": true, "options": { "collectionId": "pbc_bku", "maxSelect": 1 } },
            { "name": "jenis", "type": "select", "options": { "maxSelect": 1, "values": ["ppn", "pph"] } },
