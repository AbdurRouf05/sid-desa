[
    {
        "id": "pbc_site_config",
        "name": "site_config",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "field_company", "name": "company_name", "type": "text", "required": true, "presentable": true },
            { "id": "field_nib", "name": "nib", "type": "text" },
            { "id": "field_address", "name": "address", "type": "text" },
            { "id": "field_phone_wa", "name": "phone_wa", "type": "text" },
            { "id": "field_email", "name": "email_official", "type": "email" },
            { "id": "field_hero_title", "name": "hero_title", "type": "text" },
            { "id": "field_welcome", "name": "welcome_text", "type": "editor" },
            { "id": "field_vid_profile", "name": "video_profile_url", "type": "url" },
            { "id": "field_maint_mode", "name": "maintenance_mode", "type": "bool" },
            { "id": "field_theme", "name": "theme_config", "type": "json" },
            { "id": "field_socials", "name": "social_links", "type": "json" },
            { "id": "field_total_members", "name": "total_members", "type": "text" },
            { "id": "field_total_assets", "name": "total_assets", "type": "text" }
        ],
        "listRule": "",
        "viewRule": "",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_news",
        "name": "news",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "field_title", "name": "title", "type": "text", "required": true, "presentable": true, "options": { "min": 5 } },
            { "id": "field_slug", "name": "slug", "type": "text", "required": true, "unique": true },
            { "id": "field_content", "name": "content", "type": "editor" },
            { "id": "field_thumb", "name": "thumbnail", "type": "file", "options": { "mimeTypes": ["image/jpeg", "image/png", "image/webp"], "maxSelect": 1 } },
            { "id": "field_published", "name": "published", "type": "bool" },
            { "id": "field_category", "name": "category", "type": "select", "options": { "maxSelect": 1, "values": ["Warta Desa", "Pembangunan", "Kegiatan Masyarakat", "Pengumuman"] } }
        ],
        "listRule": "published = true",
        "viewRule": "published = true",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_products",
        "name": "products",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "field_name", "name": "name", "type": "text", "required": true, "presentable": true },
            { "id": "field_slug", "name": "slug", "type": "text", "required": true, "unique": true },
            { "id": "field_type", "name": "type", "type": "select", "options": { "maxSelect": 1, "values": ["Layanan Administratif", "Bantuan Sosial", "Fasilitas Umum"] } },
            { "id": "field_desc", "name": "description", "type": "editor" },
            { "id": "field_icon", "name": "icon", "type": "file", "options": { "mimeTypes": ["image/png", "image/jpeg", "image/svg+xml"], "maxSelect": 1 } },
            { "id": "field_featured", "name": "is_featured", "type": "bool" }
        ],
        "listRule": "",
        "viewRule": "",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_hero",
        "name": "hero_banners",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "field_title", "name": "title", "type": "text", "required": true, "presentable": true },
            { "id": "field_subtitle", "name": "subtitle", "type": "text" },
            { "id": "field_image", "name": "image_desktop", "type": "file", "required": true, "options": { "mimeTypes": ["image/jpeg", "image/png", "image/webp"], "maxSelect": 1 } },
            { "id": "field_active", "name": "active", "type": "bool" },
            { "id": "field_order", "name": "order", "type": "number", "options": { "noDecimal": true } }
        ],
        "listRule": "active = true",
        "viewRule": "active = true",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_perangkat",
        "name": "perangkat_desa",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "f_nama", "name": "nama", "type": "text", "required": true, "presentable": true },
            { "id": "f_jabatan", "name": "jabatan", "type": "text", "required": true },
            { "id": "f_nip", "name": "nip", "type": "text" },
            { "id": "f_foto", "name": "foto", "type": "file", "options": { "maxSelect": 1, "mimeTypes": ["image/*"] } },
            { "id": "f_active", "name": "is_active", "type": "bool" }
        ],
        "listRule": "",
        "viewRule": "",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_bku",
        "name": "bku_transaksi",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "f_type", "name": "type", "type": "select", "required": true, "options": { "maxSelect": 1, "values": ["masuk", "keluar", "pindah"] } },
            { "id": "f_amount", "name": "amount", "type": "number", "required": true },
            { "id": "f_tanggal", "name": "tanggal", "type": "date", "required": true },
            { "id": "f_uraian", "name": "uraian", "type": "text", "required": true },
            { "id": "f_bukti", "name": "bukti_foto", "type": "file", "options": { "maxSelect": 1, "mimeTypes": ["image/*", "application/pdf"] } },
            { "id": "f_kode", "name": "kode_anggaran", "type": "text" }
        ],
        "listRule": "@request.auth.id != ''",
        "viewRule": "@request.auth.id != ''",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_pajak",
        "name": "pajak_log",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "f_bku", "name": "bku_id", "type": "relation", "required": true, "options": { "collectionId": "pbc_bku", "maxSelect": 1 } },
            { "id": "f_jenis", "name": "jenis", "type": "select", "options": { "maxSelect": 1, "values": ["ppn", "pph21", "pph22", "pph23"] } },
            { "id": "f_nominal", "name": "nominal", "type": "number", "required": true },
            { "id": "f_disetor", "name": "is_disetor", "type": "bool" }
        ],
        "listRule": "@request.auth.id != ''",
        "viewRule": "@request.auth.id != ''",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_surat",
        "name": "surat_keluar",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "f_agenda", "name": "nomor_agenda", "type": "number", "options": { "noDecimal": true } },
            { "id": "f_kode_s", "name": "kode_surat", "type": "text", "required": true },
            { "id": "f_tujuan", "name": "tujuan", "type": "text", "required": true },
            { "id": "f_tgl", "name": "tanggal_surat", "type": "date", "required": true },
            { "id": "f_signed", "name": "signed_by", "type": "relation", "options": { "collectionId": "pbc_perangkat", "maxSelect": 1 } },
            { "id": "f_arsip", "name": "file_arsip", "type": "file", "options": { "maxSelect": 1, "mimeTypes": ["application/pdf"] } }
        ],
        "listRule": "@request.auth.id != ''",
        "viewRule": "@request.auth.id != ''",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "pbc_tanah",
        "name": "tanah_desa",
        "type": "base",
        "system": false,
        "schema": [
            { "id": "f_lokasi", "name": "lokasi", "type": "text", "required": true },
            { "id": "f_luas", "name": "luas_m2", "type": "number" },
            { "id": "f_peruntukan", "name": "peruntukan", "type": "text" },
            { "id": "f_pemegang", "name": "pemegang_hak", "type": "text" }
        ],
        "listRule": "",
        "viewRule": "",
        "createRule": "@request.auth.id != ''",
        "updateRule": "@request.auth.id != ''"
    },
    {
        "id": "_pb_users_auth_",
        "name": "users",
        "type": "auth",
        "system": false,
        "schema": [
            { "id": "users_name", "name": "name", "type": "text" },
            { "id": "users_avatar", "name": "avatar", "type": "file", "options": { "mimeTypes": ["image/*"], "maxSelect": 1 } },
            { "id": "users_role", "name": "role", "type": "select", "options": { "maxSelect": 1, "values": ["admin", "kaur", "sekdes", "staff", "member"] } }
        ],
        "listRule": "id = @request.auth.id",
        "viewRule": "id = @request.auth.id",
        "updateRule": "id = @request.auth.id",
        "deleteRule": "id = @request.auth.id",
        "options": {
            "allowEmailAuth": true,
            "allowOAuth2Auth": true,
            "allowUsernameAuth": true,
            "exceptEmailDomains": null,
            "manageRule": null,
            "minPasswordLength": 8,
            "onlyEmailDomains": null,
            "onlyVerified": false,
            "requireEmail": false
        }
    }
]
